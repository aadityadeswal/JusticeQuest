<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.JusticeQuest" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/orange_400</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">@color/orange_300</item>

        <item name="colorSecondary">@color/orange_300</item>
        <item name="colorOnSecondary">@color/white</item>

        <item name="colorSurface">@color/orange_400</item>
        <item name="colorOnSurface">@color/white</item>
        <item name="colorOnBackground">@color/black</item>

        <!-- Status Bar and Navigation Bar -->
        <item name="android:statusBarColor">@color/orange_400</item>
        <item name="android:navigationBarColor">@color/orange_400</item>

        <item name="colorControlHighlight">@color/orange_200</item>

        <item name="colorError">@color/red_500</item>


        <item name="simpleItemSelectedColor">@color/orange_400</item>
    </style>
</resources>